<h2><%= @item.name %></h2>

<p>
  <strong>SKU:</strong>
  <%= @item.sku %>
</p>

<p>
  <strong>Description:</strong>
  <%= @item.description %>
</p>

<p>
  <strong>Unit Price:</strong>
  <%= number_to_currency(@item.unit_price) %>
</p>

<p>
  <strong>Active:</strong>
  <%= @item.active ? "Yes" : "No" %>
</p>

<p>
  <%= link_to "Edit", edit_item_path(@item), class: "icon icon-edit" %>
  <%= link_to "Back", items_path %>
</p>